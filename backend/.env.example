# Local dev without Docker (default)
DATABASE_URL=sqlite:///./isinkwa_sethu.db

# PostgreSQL on localhost (e.g. docker compose up db)
# DATABASE_URL=postgresql://isinkwa:isinkwa@localhost:5432/isinkwa_sethu

JWT_SECRET=change-this-secret-in-production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# Render: set ADMIN_USERNAME and ADMIN_PASSWORD on the *API* (Docker) service,
# not the static site. Save env vars, then Manual Deploy — changes are not live until redeploy.
# If the service was created from render.yaml with generateValue, the password was random;
# override ADMIN_PASSWORD in the dashboard with your chosen secret.

# Comma-separated; include local Vite + production static URL
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://isinkwa-sethu-web.onrender.com

# Render production (set in Render dashboard for Docker service)
# DATABASE_URL=<render-postgres-internal-url>
# JWT_SECRET=<strong-secret>
# CORS_ORIGINS=https://isinkwa-sethu-web.onrender.com
