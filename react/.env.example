# Local dev: leave empty — Vite proxies /api → http://localhost:8000 (see vite.config.js)
VITE_API_URL=

# Optional: call API directly in dev (set matching CORS_ORIGINS on backend)
# VITE_API_URL=http://localhost:8000

# Production (also set in Render static site + CI build; see .env.production)
# VITE_API_URL=https://isinkwa-sethu-web-kpnm.onrender.com

# ── Sentry ────────────────────────────────────────────────────
# Create a project at sentry.io and paste its DSN here.
# Leave empty to disable Sentry (local dev without DSN).
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=production
VITE_SENTRY_RELEASE=isinkwa_sethu@1.0.0
VITE_SENTRY_TRACES_SAMPLE_RATE=0.2
VITE_SENTRY_REPLAY_SESSION_RATE=0.1
VITE_SENTRY_REPLAY_ON_ERROR_RATE=1.0

# Sentry source map upload — used by vite.config.js at build time only
# Generate at sentry.io → Settings → Auth Tokens
SENTRY_AUTH_TOKEN=
SENTRY_ORG=your-sentry-org-slug
SENTRY_PROJECT=your-sentry-project-slug
