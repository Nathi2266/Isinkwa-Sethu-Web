# Local dev: leave empty — Vite proxies /api → http://localhost:8000 (see vite.config.js)
VITE_API_URL=

# Optional: call API directly in dev (set matching CORS_ORIGINS on backend)
# VITE_API_URL=http://localhost:8000

# Production (also set in Render static site + CI build; see .env.production)
# VITE_API_URL=https://isinkwa-sethu-web-kpnm.onrender.com

# Sentry (optional)
# VITE_SENTRY_DSN=
